            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"pharmacist1\",\n  \"email\": \"pharmacist1@example.com\",\n  \"password\": \"StrongPass123!\",\n  \"password2\": \"StrongPass123!\",\n  \"first_name\": \"John\",\n  \"last_name\": \"Doe\",\n  \"phone_number\": \"+49123456789\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/v1/auth/register/",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "register",
                ""
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "let data = {};",
                  "try { data = pm.response.json(); } catch (e) { data = {}; }",
                  "const tokenObj = data.token || data.tokens || {};",
                  "const access = tokenObj.access || data.access || null;",
                  "const refresh = tokenObj.refresh || data.refresh || null;",
                  "if (access) {",
                  "  pm.collectionVariables.set('access_token', access);",
                  "  pm.globals.set('access_token', access);",
                  "  try { pm.environment.set('access_token', access); } catch (e) {}",
                  "}",
                  "if (refresh) {",
                  "  pm.collectionVariables.set('refresh_token', refresh);",
                  "  pm.globals.set('refresh_token', refresh);",
                  "  try { pm.environment.set('refresh_token', refresh); } catch (e) {}",
                  "}",
                  "pm.test('Token captured', function () {",
                  "  pm.expect(!!access).to.eql(true);",
                  "});"
                ]
              }
            }
          ]
        },
