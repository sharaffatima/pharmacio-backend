# Django
DJANGO_SETTINGS_MODULE=config.settings
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (Postgres service name = "db")
DB_NAME=pharmacio
DB_USER=pharmacio
DB_PASSWORD=pharmacio
DB_HOST=db
DB_PORT=5432

# Redis (service name = "redis") and Celery configuration
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# AWS S3 configuration
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_ENDPOINT_URL=your-s3-endpoint-url
AWS_S3_REGION_NAME=us-east-1

# File storage backend: 'local' or 's3'
FILE_STORAGE_BACKEND=local

# AI Engine API configuration
OCR_ENGINE_PROCESS_URL=http://ai-engine:8000/ocr/process
OCR_ENGINE_TIMEOUT_SECONDS=30

# API key for outbound requests to AI engine (Authorization header)
AI_ENGINE_API_KEY=dev-ai-api-key

# Token for inbound OCR callback authentication (Authorization header)
INTERNAL_SERVICE_TOKEN=shared-secret-token

# Logging configuration
LOG_LEVEL=INFO